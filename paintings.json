/* ============================================
   Aabha Joshi — Art Portfolio
   ============================================ */
:root {
  --bg: #faf7f2;
  --bg-alt: #f3ede3;
  --ink: #2b2724;
  --ink-soft: #6b625a;
  --accent: #b5542d;      /* terracotta */
  --accent-dark: #8f3f1f;
  --gold: #c9a24b;
  --card: #ffffff;
  --border: #e6ddd0;
  --sold: #9a2f2f;
  --radius: 14px;
  --shadow: 0 6px 24px rgba(43, 39, 36, 0.08);
  --shadow-lg: 0 16px 48px rgba(43, 39, 36, 0.16);
  --font-display: "Cormorant Garamond", Georgia, serif;
  --font-body: "Jost", "Segoe UI", sans-serif;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--ink);
  line-height: 1.65;
  font-size: 16.5px;
}

img { max-width: 100%; display: block; }
a { color: var(--accent); text-decoration: none; }
a:hover { color: var(--accent-dark); }

h1, h2, h3, h4 { font-family: var(--font-display); font-weight: 600; line-height: 1.2; }

.container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }

/* ---------- Header ---------- */
.site-header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(250, 247, 242, 0.92);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
}
.header-inner {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 24px; max-width: 1160px; margin: 0 auto;
}
.brand { font-family: var(--font-display); font-size: 1.7rem; font-weight: 700; color: var(--ink); letter-spacing: 0.5px; }
.brand span { color: var(--accent); }
.brand small { display: block; font-family: var(--font-body); font-size: 0.62rem; letter-spacing: 3.5px; text-transform: uppercase; color: var(--ink-soft); font-weight: 400; }

.nav { display: flex; gap: 30px; align-items: center; }
.nav a {
  color: var(--ink); font-size: 0.92rem; letter-spacing: 1.2px; text-transform: uppercase;
  padding: 6px 2px; border-bottom: 2px solid transparent; transition: 0.25s;
}
.nav a:hover, .nav a.active { color: var(--accent); border-bottom-color: var(--accent); }

.nav-toggle { display: none; background: none; border: none; font-size: 1.7rem; color: var(--ink); cursor: pointer; }

/* ---------- Hero ---------- */
.hero {
  position: relative; overflow: hidden;
  background: linear-gradient(135deg, #f6efe3 0%, #f0e2d0 45%, #e9d3bd 100%);
  padding: 110px 24px 120px;
  text-align: center;
}
.hero::before, .hero::after {
  content: ""; position: absolute; border-radius: 50%; filter: blur(60px); opacity: 0.5;
}
.hero::before { width: 420px; height: 420px; background: #e7b98a; top: -140px; left: -120px; }
.hero::after  { width: 380px; height: 380px; background: #cfa0d9; bottom: -160px; right: -100px; }
.hero > * { position: relative; z-index: 1; }
.hero .eyebrow { letter-spacing: 5px; text-transform: uppercase; font-size: 0.8rem; color: var(--accent-dark); margin-bottom: 18px; }
.hero h1 { font-size: clamp(2.6rem, 6vw, 4.6rem); font-weight: 700; margin-bottom: 20px; }
.hero h1 em { font-style: italic; color: var(--accent); }
.hero p.lede { max-width: 620px; margin: 0 auto 36px; font-size: 1.15rem; color: var(--ink-soft); }

.btn {
  display: inline-block; padding: 14px 34px; border-radius: 40px;
  background: var(--accent); color: #fff; letter-spacing: 1.5px; text-transform: uppercase;
  font-size: 0.85rem; font-weight: 500; border: none; cursor: pointer; transition: 0.25s;
}
.btn:hover { background: var(--accent-dark); color: #fff; transform: translateY(-2px); box-shadow: var(--shadow); }
.btn.ghost { background: transparent; color: var(--ink); border: 1.5px solid var(--ink); margin-left: 12px; }
.btn.ghost:hover { background: var(--ink); color: #fff; }
.btn.small { padding: 9px 22px; font-size: 0.78rem; }
.btn[disabled] { background: #b9b0a5; cursor: not-allowed; transform: none; box-shadow: none; }

/* ---------- Sections ---------- */
.section { padding: 80px 0; }
.section.alt { background: var(--bg-alt); }
.section-head { text-align: center; margin-bottom: 50px; }
.section-head .eyebrow { letter-spacing: 4px; text-transform: uppercase; font-size: 0.75rem; color: var(--accent); }
.section-head h2 { font-size: clamp(2rem, 4vw, 2.8rem); margin-top: 8px; }
.section-head p { color: var(--ink-soft); max-width: 560px; margin: 12px auto 0; }

/* ---------- Filters ---------- */
.filters { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-bottom: 44px; }
.filter-btn {
  padding: 9px 22px; border-radius: 30px; border: 1.5px solid var(--border);
  background: var(--card); color: var(--ink-soft); cursor: pointer; font-family: var(--font-body);
  font-size: 0.85rem; letter-spacing: 1px; text-transform: uppercase; transition: 0.2s;
}
.filter-btn:hover { border-color: var(--accent); color: var(--accent); }
.filter-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
.filters .divider { width: 1px; background: var(--border); margin: 4px 6px; }

/* ---------- Gallery grid ---------- */
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 34px; }

.card {
  background: var(--card); border-radius: var(--radius); overflow: hidden;
  box-shadow: var(--shadow); transition: transform 0.3s, box-shadow 0.3s;
  display: flex; flex-direction: column;
}
.card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }

.card-img { position: relative; aspect-ratio: 4 / 5; overflow: hidden; background: var(--bg-alt); }
.card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
.card:hover .card-img img { transform: scale(1.05); }

.badge {
  position: absolute; top: 14px; left: 14px; padding: 5px 14px; border-radius: 20px;
  font-size: 0.72rem; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 600; color: #fff;
}
.badge.medium { background: rgba(43, 39, 36, 0.75); backdrop-filter: blur(4px); }
.badge.sold-badge { background: var(--sold); left: auto; right: 14px; }
.badge.auction-badge { background: var(--gold); left: auto; right: 14px; top: auto; bottom: 14px; color: var(--ink); }

.sold .card-img img { filter: grayscale(0.55) brightness(0.92); }

.card-body { padding: 22px 24px 26px; display: flex; flex-direction: column; flex: 1; }
.card-body h3 { font-size: 1.45rem; margin-bottom: 4px; }
.card-meta { font-size: 0.85rem; color: var(--ink-soft); margin-bottom: 10px; }
.card-desc { font-size: 0.92rem; color: var(--ink-soft); margin-bottom: 16px; flex: 1; }

.price-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-top: auto; }
.price { font-family: var(--font-display); font-size: 1.35rem; font-weight: 700; color: var(--ink); }
.price small { display: block; font-family: var(--font-body); font-size: 0.78rem; color: var(--ink-soft); font-weight: 400; }
.sold-label { color: var(--sold); font-weight: 600; letter-spacing: 2px; text-transform: uppercase; font-size: 0.85rem; }

.auction-note { margin-top: 12px; font-size: 0.82rem; color: #8a6d1f; background: #faf3dd; border: 1px solid #eddfae; border-radius: 8px; padding: 8px 12px; }

/* ---------- Modal ---------- */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(30, 26, 22, 0.6); z-index: 200;
  display: none; align-items: center; justify-content: center; padding: 20px;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--card); border-radius: var(--radius); max-width: 520px; width: 100%;
  max-height: 92vh; overflow-y: auto; padding: 36px; position: relative; box-shadow: var(--shadow-lg);
}
.modal-close {
  position: absolute; top: 14px; right: 18px; background: none; border: none;
  font-size: 1.9rem; color: var(--ink-soft); cursor: pointer; line-height: 1;
}
.modal h3 { font-size: 1.7rem; margin-bottom: 4px; }
.modal .modal-sub { color: var(--ink-soft); font-size: 0.92rem; margin-bottom: 18px; }

.contact-box {
  background: var(--bg-alt); border-radius: 10px; padding: 14px 18px; margin-bottom: 20px;
  font-size: 0.92rem;
}
.contact-box strong { display: block; margin-bottom: 4px; font-size: 0.8rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); }

.form-group { margin-bottom: 16px; }
.form-group label { display: block; font-size: 0.82rem; letter-spacing: 1px; text-transform: uppercase; color: var(--ink-soft); margin-bottom: 6px; }
.form-group input, .form-group textarea, .form-group select {
  width: 100%; padding: 12px 14px; border: 1.5px solid var(--border); border-radius: 8px;
  font-family: var(--font-body); font-size: 0.95rem; background: #fff; color: var(--ink);
}
.form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--accent); }
.form-note { font-size: 0.8rem; color: var(--ink-soft); margin-top: 10px; }
.form-status { margin-top: 12px; font-size: 0.9rem; font-weight: 500; }
.form-status.ok { color: #2e7d46; }
.form-status.err { color: var(--sold); }

/* ---------- Blog ---------- */
.post-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px; }
.post-card {
  background: var(--card); border-radius: var(--radius); padding: 30px 30px 26px;
  box-shadow: var(--shadow); transition: transform 0.3s; display: flex; flex-direction: column;
}
.post-card:hover { transform: translateY(-5px); }
.post-cat { font-size: 0.72rem; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); font-weight: 600; }
.post-card h3 { font-size: 1.5rem; margin: 8px 0 6px; }
.post-card h3 a { color: var(--ink); }
.post-card h3 a:hover { color: var(--accent); }
.post-date { font-size: 0.82rem; color: var(--ink-soft); margin-bottom: 12px; }
.post-excerpt { color: var(--ink-soft); font-size: 0.95rem; flex: 1; }
.read-more { margin-top: 16px; font-size: 0.85rem; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 600; }

.post-full { max-width: 720px; margin: 0 auto; }
.post-full h1 { font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 10px; }
.post-full .post-date { margin-bottom: 30px; }
.post-full p { margin-bottom: 20px; font-size: 1.05rem; }

/* ---------- Exhibitions ---------- */
.exhibit {
  background: var(--card); border-radius: var(--radius); box-shadow: var(--shadow);
  padding: 34px 38px; margin-bottom: 26px; display: grid; grid-template-columns: 130px 1fr; gap: 30px;
}
.exhibit-date {
  text-align: center; align-self: start; background: var(--bg-alt); border-radius: 12px; padding: 16px 10px;
}
.exhibit-date .day { font-family: var(--font-display); font-size: 2.2rem; font-weight: 700; color: var(--accent); line-height: 1; }
.exhibit-date .monthyear { font-size: 0.8rem; letter-spacing: 1.5px; text-transform: uppercase; color: var(--ink-soft); margin-top: 4px; }
.exhibit h3 { font-size: 1.7rem; margin-bottom: 4px; }
.exhibit .venue { color: var(--ink-soft); font-size: 0.95rem; margin-bottom: 12px; }
.exhibit .paintings-in { margin-top: 14px; font-size: 0.88rem; }
.exhibit .paintings-in span {
  display: inline-block; background: #faf3dd; border: 1px solid #eddfae; color: #8a6d1f;
  border-radius: 20px; padding: 4px 14px; margin: 4px 6px 0 0; font-size: 0.8rem;
}
.exhibit.past { opacity: 0.65; }
.exhibit .status-tag { font-size: 0.72rem; letter-spacing: 2px; text-transform: uppercase; font-weight: 700; }
.exhibit .status-tag.upcoming { color: #2e7d46; }
.exhibit .status-tag.past-tag { color: var(--ink-soft); }

/* ---------- About ---------- */
.about-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: center; }
.about-photo {
  aspect-ratio: 4/5; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-lg);
  background: linear-gradient(140deg, #e8c9a8, #cfa0d9);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-size: 5rem; color: rgba(255,255,255,0.85);
}
.about-photo img { width: 100%; height: 100%; object-fit: cover; }
.about-text h2 { font-size: 2.4rem; margin-bottom: 18px; }
.about-text p { color: var(--ink-soft); margin-bottom: 16px; }

/* ---------- Footer ---------- */
.site-footer { background: #241f1b; color: #cfc5ba; padding: 60px 24px 30px; margin-top: 40px; }
.footer-grid { max-width: 1160px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 40px; }
.site-footer h4 { color: #fff; font-size: 1.3rem; margin-bottom: 14px; }
.site-footer a { color: #e0b48a; }
.site-footer ul { list-style: none; }
.site-footer li { margin-bottom: 8px; font-size: 0.92rem; }
.footer-bottom { text-align: center; margin-top: 46px; padding-top: 22px; border-top: 1px solid #3a332c; font-size: 0.82rem; color: #8f857a; }

/* ---------- Empty state ---------- */
.empty-state { text-align: center; color: var(--ink-soft); padding: 60px 0; font-style: italic; }

/* ---------- Responsive ---------- */
@media (max-width: 820px) {
  .nav {
    position: absolute; top: 100%; left: 0; right: 0; background: var(--bg);
    flex-direction: column; gap: 0; border-bottom: 1px solid var(--border);
    max-height: 0; overflow: hidden; transition: max-height 0.3s;
  }
  .nav.open { max-height: 400px; }
  .nav a { padding: 14px 24px; width: 100%; border-bottom: 1px solid var(--border); }
  .nav-toggle { display: block; }
  .about-grid { grid-template-columns: 1fr; }
  .exhibit { grid-template-columns: 1fr; padding: 26px; }
  .exhibit-date { display: inline-block; padding: 10px 18px; }
  .btn.ghost { margin-left: 0; margin-top: 12px; }
}

/* image fallback when photo missing */
.card-img.img-fallback::before {
  content: attr(data-title);
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(140deg, #e8c9a8, #cfa0d9);
  font-family: var(--font-display); font-size: 1.6rem; color: #fff; padding: 20px; text-align: center;
}
